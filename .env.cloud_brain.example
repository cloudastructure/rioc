# Cloud Brain (run on AWS EC2)
# Copy to .env in the rioc directory on your EC2 instance

# Mac stream URL - use your Cloudflare Tunnel or ngrok URL
STREAM_URL=https://xxx-xxx-xxx.trycloudflare.com

# vLLM OpenAI-compatible API (localhost if vLLM runs on same EC2; RunPod: https://api.runpod.ai/v2/<ENDPOINT_ID>/openai/v1)
VLLM_BASE_URL=http://localhost:8000/v1

# Model name - must match what vLLM/RunPod is serving (e.g. openbmb/MiniCPM-V-2_6-int4)
MODEL_NAME=openbmb/MiniCPM-V-2_6-int4

# Must match vLLM --api-key (RunPod: use your RunPod API key)
OPENAI_API_KEY=token-rioc

# Seconds between audits (default 5.0)
AUDIT_INTERVAL_SEC=5.0
