# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get an API key at https://platform.openai.com/api-keys
OPENAI_STT_API_KEY=sk-proj-your-key-here

# Optional: VideoDB eyes and ears (ENABLE_VIDEODB=1)
# Get key at https://console.videodb.io (free tier: 50 uploads)
# VIDEODB_API_KEY=your-videodb-key
# For your own webcam/mic: run MediaMTX + FFmpeg, expose RTSP, then:
# VIDEODB_RTSP_VIDEO=rtsp://your-tunnel:8554/cam
# VIDEODB_RTSP_AUDIO=rtsp://your-tunnel:8554/mic

# Optional: Use external speaker mic for audio input (Fanvil CS20 via USB, etc.)
# Device index (e.g. 1) or name substring (e.g. Fanvil, LINKVIL, CS20)
# AUDIO_INPUT_DEVICE=Fanvil
# AUDIO_INPUT_DEVICE=1

# Optional: IP speaker for Rioc TTS (set ENABLE_SPEAKER_TTS=1)
# Speaker URL, auth, and play endpoint (device API varies — check your speaker docs)
SPEAKER_URL=https://192.168.10.183
SPEAKER_WS_URL=wss://192.168.10.183:8000/webtwowayaudio
SPEAKER_USER=admin
SPEAKER_PASS=your-password
SPEAKER_PLAY_PATH=/play
# For play-from-URL mode: your Mac's IP so the speaker can fetch TTS (e.g. http://192.168.10.50:8000)
TTS_PUBLIC_URL=
